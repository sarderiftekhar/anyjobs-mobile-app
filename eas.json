{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://dev.any-jobs.com/api"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.any-jobs.com/api"
      },
      "ios": {
        "bundleIdentifier": "com.anyjobs.mobile"
      },
      "android": {
        "package": "com.anyjobs.mobile",
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
